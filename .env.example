# Spotify API Credentials
# Get these from: https://developer.spotify.com/dashboard

# Required: Your Spotify Client ID
SPOTIFY_CLIENT_ID=your_client_id_here

# Required: Your Spotify Client Secret
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Required: Redirect URI (must match Spotify Dashboard)
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:1422/callback

# Optional: Debug mode (shows token in console)
# VITE_SPX_DEBUG_TOKEN=1

# Optional: Mock mode (uses fake data, no Spotify needed)
# VITE_SPX_MOCK=1

# Optional: WebSocket URL (default: ws://127.0.0.1:1424)
# VITE_WS_URL=ws://127.0.0.1:1424

# Optional: Spotify Web Player sp_dc cookie.
# Required for activating Google Cast / Chromecast devices directly.
# Get it from your browser's cookies for https://open.spotify.com
# SPOTIFY_SP_DC=AQ...
