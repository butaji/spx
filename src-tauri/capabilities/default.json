{
  "$schema": "../gen/schemas/capabilities-schema.json",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "scheme": "https",
          "domain": "accounts.spotify.com"
        },
        {
          "scheme": "https",
          "domain": "open.spotify.com"
        },
        {
          "scheme": "https",
          "domain": "developer.spotify.com"
        }
      ]
    },
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-hide",
    "store:allow-load",
    "store:allow-save",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-clear",
    "store:allow-keys",
    "store:allow-values",
    "store:allow-length",
    "store:allow-entries",
    "global-shortcut:default"
  ]
}