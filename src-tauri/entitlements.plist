<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow outbound network connections -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Allow inbound network connections (for OAuth callback) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- File access for auth token storage -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Bonjour/mDNS for device discovery -->
    <key>com.apple.security.network.bonjour</key>
    <true/>
    <!-- Local network multicast -->
    <key>com.apple.security.network.multicast</key>
    <true/>

</dict>
</plist>
