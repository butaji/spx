{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SPX",
  "version": "0.1.0",
  "identifier": "com.spx.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SPX",
        "width": 900,
        "height": 580,
        "minWidth": 720,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:1420 https://api.spotify.com https://accounts.spotify.com; font-src 'self' https://fonts.gstatic.com; style-src 'self' https://fonts.googleapis.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["com.spx.app"]
      }
    }
  }
}
